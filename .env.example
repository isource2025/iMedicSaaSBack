# === OBLIGATORIAS en Railway (servicio backend) — datos clínicos SQL Server ===
# Railway NO lee el .env del repo; cargá cada variable en Variables del servicio.
DB_SERVER=your_server_ip
DB_PORT=1433
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name
# DB_INSTANCE=SQLEXPRESS

JWT_SECRET=change-me-in-production
PLATFORM_DB_SECRET=change-me-in-production
CORS_ORIGINS=https://tu-front.vercel.app,http://localhost:3000

# PORT lo define Railway automáticamente (ej. 8080)

# === MySQL en Railway (login central, opcional) ===
AUTH_DB_ENABLED=1
AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=0

# Archivos adjuntos - Servidor HTTP de archivos
# URL del servidor HTTP que maneja la subida y descarga de archivos
# Este servidor debe estar corriendo en la máquina que tiene acceso al disco E:\
# Para desarrollo local: http://localhost:3002
# Para producción con túnel: https://tu-tunnel-url.trycloudflare.com
FILE_SERVER_URL=http://localhost:3002
FILE_SERVER_PORT=3002

# Si FILE_SERVER_URL no es alcanzable (timeout/VPN), guardar la ruta absoluta del archivo
# en el disco del backend (uploads/...) y registrarla en BD. Descarga vía GET .../download lee ese disco.
# Valor 1 = activado (útil en desarrollo o si aún no hay túnel al servidor de archivos).
FILE_SERVER_FALLBACK_LOCAL=0

# URL del túnel (actualizar después de iniciar cloudflared)
# Ejemplo: https://abc123.trycloudflare.com
TUNNEL_URL=

# --- Chatbot WhatsApp (API /api/integrations/bot) ---
BOT_API_KEY=
BOT_EMPRESA_ID=1
# 1 = al elegir especialidad propone UN turno cercano (no lista profesionales). Gana sobre imBotConfig.
BOT_SUGERIR_PRIMER_TURNO=1
# Anticipación, búsqueda de turnos, etc.: Panel Bot → Reglas (imBotConfig). Env solo como fallback de deploy.
# BOT_ANTICIPACION_MIN_HORAS=2
# BOT_BUSQUEDA_MAX_DIAS=21
# BOT_MAX_PROF_BUSQUEDA=12
# BOT_BUSQUEDA_CONCURRENCIA=4
# BOT_TURNO_BUSQUEDA_TIMEOUT_MS=12000

# Comando WhatsApp testing: #IMEDIC-ZERO-TODO#<este-pin>
# BOT_WHATSAPP_RESET_PIN=reset-imedic-dev

# Meta WhatsApp Cloud API — webhook público
# Callback URL en Meta: https://TU-DOMINIO/api/webhook/whatsapp
WHATSAPP_VERIFY_TOKEN=imedic_verify_2026
# WHATSAPP_APP_SECRET=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# Transcripción de audios entrantes (Groq Whisper)
# Si GROQ_API_KEY está vacío, los audios se guardan como "(audio sin transcripción)".
GROQ_API_KEY=
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# GROQ_TRANSCRIBE_LANG=es
# BOT_AUDIO_TRANSCRIBE=1
# BOT_AUDIO_MAX_MB=25
# GROQ_TRANSCRIBE_TIMEOUT_MS=45000

AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=1
