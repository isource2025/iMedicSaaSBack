# === OBLIGATORIAS en Railway (servicio backend) — datos clínicos SQL Server ===
# Railway NO lee el .env del repo; cargá cada variable en Variables del servicio.
DB_SERVER=your_server_ip
DB_PORT=1433
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name
# DB_INSTANCE=SQLEXPRESS

JWT_SECRET=change-me-in-production
PLATFORM_DB_SECRET=change-me-in-production
CORS_ORIGINS=https://tu-front.vercel.app,http://localhost:3000

# PORT lo define Railway automáticamente (ej. 8080)

# === MySQL en Railway (login central, opcional) ===
AUTH_DB_ENABLED=1
AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=0

# Archivos adjuntos - Servidor HTTP de archivos
# URL del servidor HTTP que maneja la subida y descarga de archivos
# Este servidor debe estar corriendo en la máquina que tiene acceso al disco E:\
# Para desarrollo local: http://localhost:3002
# Para producción con túnel: https://tu-tunnel-url.trycloudflare.com
FILE_SERVER_URL=http://localhost:3002
FILE_SERVER_PORT=3002

# Si FILE_SERVER_URL no es alcanzable (timeout/VPN), guardar la ruta absoluta del archivo
# en el disco del backend (uploads/...) y registrarla en BD. Descarga vía GET .../download lee ese disco.
# Valor 1 = activado (útil en desarrollo o si aún no hay túnel al servidor de archivos).
FILE_SERVER_FALLBACK_LOCAL=0

# URL del túnel (actualizar después de iniciar cloudflared)
# Ejemplo: https://abc123.trycloudflare.com
TUNNEL_URL=

# Auth central en Railway MySQL (login nucleado)
AUTH_DB_ENABLED=0
AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=1
