# Database Configuration
DB_SERVER=your_server_ip
DB_PORT=1433
DB_USER=your_username
DB_PASSWORD=your_password
DB_DATABASE=your_database_name

# Server Configuration
PORT=3001

# Archivos adjuntos - Servidor de archivos (NAS)
# URL base del servidor de archivos donde están almacenados los PDFs/imágenes
# Ejemplo: http://181.4.71.230:8080/files
# Si se configura, el sistema redirigirá a esta URL en lugar de servir archivos localmente
FILE_SERVER_URL=

# Archivos adjuntos - Path base para archivos viejos (solo si no se usa FILE_SERVER_URL)
# Este path se usa para buscar archivos que están en ubicaciones antiguas (E:\imagenes, etc.)
# En producción, configurar según donde estén montados los archivos del sistema viejo
ARCHIVOS_BASE_PATH=E:\imagenes
