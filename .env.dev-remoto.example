# =============================================================================
# Copiar a .env en la PC del DEV (NO en la PC host WEBDEV)
# El SQL vive en la máquina de iSource; el dev corre back/front en su PC.
# =============================================================================

PORT=5006
AUTH_DB_ENABLED=0
LOCAL_DEV_ONLY=1

# --- Opción A: dev en otra red / internet (IP pública del host) ---
DB_SERVER=181.98.96.200
DB_PORT=1433

# --- Opción B: misma Wi‑Fi/LAN que el host — comentá A y usá esto ---
# DB_SERVER=192.168.1.47
# DB_PORT=1433

DB_NAME=iSource
DB_USER=sa
DB_PASSWORD=isource

JWT_SECRET=change-me-in-production
PLATFORM_DB_SECRET=imedic-platform-dev-secret-change-in-prod
CORS_ORIGINS=http://localhost:3000

BOT_EMPRESA_ID=1

# Validación afiliados (opcional)
# IOSCOR_API_URL=https://apiservice.ioscor.gob.ar/api/v1
# IOSCOR_API_ID=
# IOSCOR_API_KEY=

# Front del dev (en su PC): iMedicSaaSFront/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:5006/api
