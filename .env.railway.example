# Railway — Variables del servicio BACKEND (no commitear secretos)
# Opción A: vincular plugin MySQL al backend (Railway inyecta MYSQLHOST, MYSQLUSER, …)
# Opción B: referencias manuales, ej. AUTH_DB_HOST=${{MySQL.MYSQLHOST}}

AUTH_DB_ENABLED=1
AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=0

# Si vinculás MySQL, también valen MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE

JWT_SECRET=
# Obligatorio si Empresas usa DbPasswordEnc (mismo valor que al ejecutar setup_empresa_conexion.js en local)
PLATFORM_DB_SECRET=imedic-platform-dev-secret-change-in-prod
CORS_ORIGINS=https://tu-front-2.vercel.app,http://localhost:3000

# SQL plataforma opcional si todo el catálogo está en MySQL Empresas:
# DB_SERVER=
# DB_PORT=1433
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# --- Chatbot WhatsApp (API /api/integrations/bot) ---
# Una empresa: BOT_API_KEY + BOT_EMPRESA_ID
# Multi-tenant: BOT_API_KEYS={"1":"clave-empresa-1","2":"clave-empresa-2"}
BOT_API_KEY=
BOT_EMPRESA_ID=1
# BOT_API_KEYS={"1":"genera-clave-segura-aqui"}

# --- Meta WhatsApp Cloud API (webhook público) ---
# Callback URL en Meta:
#   https://imedicwsback-production.up.railway.app/api/webhook/whatsapp
WHATSAPP_VERIFY_TOKEN=imedic_verify_2026
META_APP_ID=
META_APP_SECRET=
# Si Graph API OK pero HMAC falla con facebookexternalua (proxy Railway), habilitar:
WHATSAPP_WEBHOOK_TRUST_META_UA=1
# BOT_WHATSAPP_RESET_PIN=reset-imedic-dev
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

BOT_COD_OPERADOR=999
BOT_NOMBRE_INSTITUCION=Hospital iMedic
BOT_ANTICIPACION_MIN_HORAS=2
BOT_DIAS_MAX_ANTELACION=60
BOT_MAX_TURNOS_POR_PACIENTE_DIA=1
BOT_REQUIERE_DNI=1
BOT_REQUIERE_RENAPER=1
BOT_CREAR_PACIENTE_AUTO=1
BOT_PERMITE_SOBRETURNO=0
