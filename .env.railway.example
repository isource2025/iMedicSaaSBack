# Railway — Variables del servicio BACKEND (no commitear secretos)
# Opción A: vincular plugin MySQL al backend (Railway inyecta MYSQLHOST, MYSQLUSER, …)
# Opción B: referencias manuales, ej. AUTH_DB_HOST=${{MySQL.MYSQLHOST}}

AUTH_DB_ENABLED=1
AUTH_DB_HOST=
AUTH_DB_PORT=3306
AUTH_DB_USER=
AUTH_DB_PASSWORD=
AUTH_DB_NAME=
AUTH_DB_SSL=0

# Si vinculás MySQL, también valen MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE

JWT_SECRET=
PLATFORM_DB_SECRET=
CORS_ORIGINS=https://tu-front-2.vercel.app,http://localhost:3000

# SQL plataforma opcional si todo el catálogo está en MySQL Empresas:
# DB_SERVER=
# DB_PORT=1433
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
